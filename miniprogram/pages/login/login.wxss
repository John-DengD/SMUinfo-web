.auth-page {
  display: flex;
  align-items: center;
  min-height: 100vh;
}

.auth-card {
  width: 100%;
  padding: 36rpx 30rpx;
}

.brand {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.brand-mark {
  width: 88rpx;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  background: linear-gradient(135deg, #ff3158, #7c3aed);
  border: 4rpx solid #1b1026;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 900;
  box-shadow: 5rpx 5rpx 0 #1b1026;
}

.brand-name {
  font-size: 38rpx;
  font-weight: 900;
  white-space: nowrap;
  transform: skew(-6deg);
}

.title {
  font-size: 42rpx;
  font-weight: 900;
  color: #1b1026;
}

.subtitle {
  margin: 8rpx 0 28rpx;
  color: #7a3414;
  font-size: 26rpx;
  font-weight: 700;
}

.submit {
  margin-top: 16rpx;
}

.switch {
  margin-top: 18rpx;
}
