<view class="page publish-page">
  <view class="form-card">
    <view class="page-title">发布闲置</view>
    <view class="page-sub">填写商品信息，建议校内当面确认交易</view>

    <view class="field">
      <text class="label">商品标题</text>
      <input class="input" maxlength="80" value="{{form.title}}" placeholder="一句话说清楚商品" bindinput="onInput" data-field="title" />
    </view>

    <view class="field">
      <text class="label">分类</text>
      <picker range="{{categories}}" range-key="name" value="{{categoryIndex}}" bindchange="onCategoryChange">
        <view class="picker-box">{{categoryDisplay}}</view>
      </picker>
    </view>

    <view class="field">
      <text class="label">价格</text>
      <input class="input" type="digit" value="{{form.price}}" placeholder="例如：39.9" bindinput="onInput" data-field="price" />
    </view>

    <view class="field">
      <text class="label">原价</text>
      <input class="input" type="digit" value="{{form.originalPrice}}" placeholder="可选" bindinput="onInput" data-field="originalPrice" />
    </view>

    <view class="field">
      <text class="label">商品成色</text>
      <picker range="{{conditionOptions}}" value="{{conditionIndex}}" bindchange="onConditionChange">
        <view class="picker-box">{{conditionName}}</view>
      </picker>
    </view>

    <view class="field">
      <text class="label">交易地点</text>
      <input class="input" value="{{form.tradeLocation}}" placeholder="例如：主校区图书馆门口" bindinput="onInput" data-field="tradeLocation" />
    </view>

    <view class="field">
      <text class="label">商品描述</text>
      <textarea class="textarea" maxlength="2000" value="{{form.description}}" placeholder="说明商品状况、瑕疵、配件等" bindinput="onInput" data-field="description" />
    </view>

    <view class="field">
      <text class="label">商品图片</text>
      <view class="image-grid">
        <view wx:for="{{imageUrls}}" wx:key="*this" class="image-item">
          <image class="image-thumb" src="{{item}}" mode="aspectFill" />
          <view class="remove" bindtap="removeImage" data-index="{{index}}">×</view>
        </view>
        <view wx:if="{{imageUrls.length < 9}}" class="image-add" bindtap="chooseImages">+</view>
      </view>
    </view>

    <button class="primary-btn" loading="{{loading}}" bindtap="submit">发布</button>
  </view>
</view>
