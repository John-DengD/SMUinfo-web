.page-title {
  color: #1b1026;
  font-size: 40rpx;
  font-weight: 900;
}

.page-sub {
  margin: 8rpx 0 28rpx;
  color: #7a3414;
  font-size: 25rpx;
  font-weight: 700;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.image-item,
.image-add {
  position: relative;
  height: 210rpx;
  overflow: hidden;
  border: 4rpx solid #1b1026;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #ffe066, #8ff3ff);
}

.image-thumb {
  width: 100%;
  height: 100%;
}

.image-add {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1b1026;
  font-size: 72rpx;
  font-weight: 900;
}

.remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 42rpx;
  height: 42rpx;
  line-height: 38rpx;
  text-align: center;
  color: #fff;
  background: rgba(17, 24, 39, 0.72);
  border-radius: 50%;
  font-size: 34rpx;
}
