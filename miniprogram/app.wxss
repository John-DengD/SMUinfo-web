page {
  min-height: 100%;
  background: #fff7d6;
  color: #1b1026;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.brand-word {
  display: inline-block;
  color: #1b1026;
  font-family: Impact, "Arial Black", "PingFang SC", sans-serif;
  font-weight: 900;
  line-height: 1;
  letter-spacing: 0;
  text-shadow:
    3rpx 0 #fffef6,
    -3rpx 0 #fffef6,
    0 3rpx #fffef6,
    0 -3rpx #fffef6,
    7rpx 7rpx 0 #1b1026;
}

.brand-word-cute {
  color: #ff3158;
  transform: rotate(-4deg);
}

.brand-word-jone {
  color: #ffd23f;
  transform: rotate(3deg);
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 12% 10%, rgba(255, 72, 97, 0.22) 0, rgba(255, 72, 97, 0.22) 70rpx, transparent 72rpx),
    radial-gradient(circle at 88% 18%, rgba(74, 222, 128, 0.18) 0, rgba(74, 222, 128, 0.18) 86rpx, transparent 88rpx),
    linear-gradient(135deg, #fff7d6 0%, #ffe6f1 48%, #dff9ff 100%);
}

.surface {
  position: relative;
  background: #fffef6;
  border: 4rpx solid #1b1026;
  border-radius: 24rpx;
  box-shadow: 8rpx 8rpx 0 #1b1026;
}

.primary-btn {
  background: linear-gradient(135deg, #ff3158, #ff8a00);
  color: #fff;
  border: 4rpx solid #1b1026;
  border-radius: 18rpx;
  font-size: 30rpx;
  font-weight: 800;
  box-shadow: 6rpx 6rpx 0 #1b1026;
}

.ghost-btn {
  background: #8ff3ff;
  color: #1b1026;
  border: 4rpx solid #1b1026;
  border-radius: 18rpx;
  font-size: 30rpx;
  font-weight: 800;
  box-shadow: 6rpx 6rpx 0 #1b1026;
}

.muted {
  color: #6b7280;
}

.empty {
  margin-top: 24rpx;
  padding: 80rpx 24rpx;
  text-align: center;
  color: #6d5b2f;
  background: #fffef6;
  border: 4rpx dashed #1b1026;
  border-radius: 24rpx;
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.product-card {
  position: relative;
  overflow: hidden;
  background: #fffef6;
  border: 4rpx solid #1b1026;
  border-radius: 22rpx;
  box-shadow: 7rpx 7rpx 0 #1b1026;
}

.product-cover {
  width: 100%;
  height: 330rpx;
  background:
    repeating-linear-gradient(-45deg, rgba(27, 16, 38, 0.08) 0 8rpx, transparent 8rpx 18rpx),
    linear-gradient(135deg, #ffe066, #8ff3ff);
  border-bottom: 4rpx solid #1b1026;
}

.product-body {
  padding: 16rpx;
}

.product-title {
  height: 76rpx;
  color: #1b1026;
  font-size: 28rpx;
  line-height: 38rpx;
  overflow: hidden;
  font-weight: 700;
}

.product-price {
  margin-top: 8rpx;
  color: #d21f3c;
  font-size: 36rpx;
  font-weight: 900;
}

.product-meta {
  margin-top: 6rpx;
  color: #6d5b2f;
  font-size: 22rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.form-card {
  padding: 28rpx;
  background: #fffef6;
  border: 4rpx solid #1b1026;
  border-radius: 26rpx;
  box-shadow: 8rpx 8rpx 0 #1b1026;
}

.field {
  margin-bottom: 22rpx;
}

.label {
  display: block;
  margin-bottom: 10rpx;
  color: #1b1026;
  font-size: 26rpx;
  font-weight: 800;
}

.input,
.textarea,
.picker-box {
  width: 100%;
  min-height: 82rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  background: #fff;
  border: 4rpx solid #1b1026;
  border-radius: 16rpx;
  color: #1b1026;
  font-size: 28rpx;
}

.textarea {
  min-height: 180rpx;
  padding-top: 18rpx;
  line-height: 38rpx;
}

.picker-box {
  display: flex;
  align-items: center;
}

.cute-tabbar {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: 22rpx;
  z-index: 70;
  height: 124rpx;
  padding: 13rpx;
  display: flex;
  gap: 14rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 12% 24%, rgba(255, 210, 63, 0.46) 0 14rpx, transparent 16rpx),
    radial-gradient(circle at 90% 70%, rgba(143, 243, 255, 0.56) 0 18rpx, transparent 20rpx),
    rgba(255, 254, 246, 0.97);
  border: 5rpx solid #1b1026;
  border-radius: 38rpx;
  box-shadow: 8rpx 8rpx 0 #1b1026;
}

.cute-tab {
  position: relative;
  flex: 1;
  height: 90rpx;
  padding: 0 16rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: #1b1026;
  background:
    linear-gradient(180deg, #fffef6 0%, #fff0c2 100%);
  border: 3rpx solid #1b1026;
  border-radius: 30rpx;
  transform: rotate(-1deg);
  overflow: hidden;
}

.cute-tab::before {
  content: "";
  position: absolute;
  left: -20rpx;
  top: -38rpx;
  width: 96rpx;
  height: 96rpx;
  background: rgba(255, 49, 88, 0.14);
  border-radius: 50%;
}

.cute-tab.active {
  color: #fffef6;
  background:
    radial-gradient(circle at 20% 24%, rgba(255, 254, 246, 0.24) 0 15rpx, transparent 17rpx),
    linear-gradient(135deg, #ff3158 0%, #ff8a00 52%, #7c3aed 100%);
  box-shadow: 5rpx 5rpx 0 #1b1026;
  transform: rotate(1.5deg) translateY(-6rpx);
}

.cute-tab-mark {
  position: relative;
  z-index: 1;
  width: 50rpx;
  height: 50rpx;
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1b1026;
  background: #ffd23f;
  border: 3rpx solid #1b1026;
  border-radius: 18rpx;
  font-family: Impact, "Arial Black", "PingFang SC", sans-serif;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 50rpx;
  box-shadow: 3rpx 3rpx 0 #1b1026;
  transform: rotate(-8deg);
}

.cute-tab-copy {
  position: relative;
  z-index: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.cute-tab-main {
  font-family: "Comic Sans MS", "Arial Rounded MT Bold", "PingFang SC", sans-serif;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 1;
  letter-spacing: 0;
  color: #ff3158;
  text-shadow:
    2rpx 0 #fffef6,
    -2rpx 0 #fffef6,
    0 2rpx #fffef6,
    0 -2rpx #fffef6,
    4rpx 4rpx 0 #1b1026;
}

.cute-tab-sub {
  margin-top: 7rpx;
  color: #7a3414;
  font-size: 17rpx;
  line-height: 1;
  font-weight: 900;
}

.cute-tab.active .cute-tab-main {
  color: #fffef6;
  text-shadow: 4rpx 4rpx 0 #1b1026;
}

.cute-tab.active .cute-tab-sub {
  color: #fff3b0;
}
